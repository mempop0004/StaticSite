{
  "name": "astro-blog-demo",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "node scripts/generate-style-files.mjs && node scripts/generate-post-files.mjs",
    "prebuild": "node scripts/generate-style-files.mjs && node scripts/generate-post-files.mjs",
    "postbuild": "node scripts/verify-generated-feeds.mjs",
    "prepreview": "node scripts/generate-style-files.mjs && node scripts/generate-post-files.mjs",
    "blog:settings:new": "node scripts/create-blog-settings.mjs",
    "blog:build": "node scripts/run-blog-command.mjs build",
    "blog:dev": "node scripts/run-blog-command.mjs dev",
    "blog:preview": "node scripts/run-blog-command.mjs preview",
    "post:new": "node scripts/create-post-workspace.mjs",
    "post:focus": "node scripts/focus-post-workspace.mjs",
    "review:post": "node scripts/review-post-with-gemini.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy:live": "node scripts/deploy-live-repos.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.5",
    "sharp": "^0.34.3"
  }
}
