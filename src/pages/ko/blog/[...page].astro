---
import PostFeed from '../../../components/PostFeed.astro';
import MainLayout from '../../../layouts/MainLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../config/site';
import { getBlogPosts, INITIAL_POST_LIMIT } from '../../../lib/blog';

export async function getStaticPaths({ paginate }) {
	const posts = await getBlogPosts('ko');

	return paginate(posts, {
		pageSize: INITIAL_POST_LIMIT,
		params: {},
	});
}

const { page } = Astro.props;
---

<MainLayout locale="ko" title={`${SITE_TITLE} | 전체 글`} description={SITE_DESCRIPTION} mainClass="page-shell">
	<PostFeed
		locale="ko"
		title="전체 글"
		description="한국어 포스트 전체 목록."
		posts={page.data}
		page={{
			currentPage: page.currentPage,
			lastPage: page.lastPage,
			prevUrl: page.url.prev,
			nextUrl: page.url.next,
		}}
		titleClass="post-card-title--ko-list"
		titleTag="h4"
	/>
</MainLayout>
