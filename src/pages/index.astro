---
import PostFeed from '../components/PostFeed.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { getBlogPosts, getVisiblePosts } from '../lib/blog';
import { SITE_DESCRIPTION, SITE_TITLE } from '../config/site';

const posts = getVisiblePosts(await getBlogPosts('en'));
---

<MainLayout locale="en" title={SITE_TITLE} description={SITE_DESCRIPTION} mainClass="page-shell">
	<PostFeed
		locale="en"
		title={SITE_TITLE}
		description={SITE_DESCRIPTION}
		posts={posts}
		titleClass="post-card-title--en"
		titleTag="h2"
	/>
</MainLayout>
