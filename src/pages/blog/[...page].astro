---
import PostFeed from '../../components/PostFeed.astro';
import MainLayout from '../../layouts/MainLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../config/site';
import { getBlogPosts, INITIAL_POST_LIMIT } from '../../lib/blog';

export async function getStaticPaths({ paginate }) {
	const posts = await getBlogPosts('en');

	return paginate(posts, {
		pageSize: INITIAL_POST_LIMIT,
		params: {},
	});
}

const { page } = Astro.props;
---

<MainLayout locale="en" title={`${SITE_TITLE} | Posts`} description={SITE_DESCRIPTION} mainClass="page-shell">
	<PostFeed
		locale="en"
		title="All posts"
		description="Browse the full English post list."
		posts={page.data}
		page={{
			currentPage: page.currentPage,
			lastPage: page.lastPage,
			prevUrl: page.url.prev,
			nextUrl: page.url.next,
		}}
		titleClass="post-card-title--en"
		titleTag="h4"
	/>
</MainLayout>
