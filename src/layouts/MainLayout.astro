---
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import type { Locale } from '../config/i18n';

interface Props {
	title: string;
	description: string;
	locale?: Locale;
	image?: ImageMetadata;
	mainClass?: string;
}

const { title, description, locale = 'en', image, mainClass } = Astro.props;
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead locale={locale} title={title} description={description} image={image} />
	</head>
	<body>
		<Header locale={locale} />
		<main class={mainClass}>
			<slot />
		</main>
		<Footer locale={locale} />
		<script is:inline src="/code-copy.js"></script>
		<slot name="body-end" />
	</body>
</html>
